generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TrackingEvent {
  id                Int      @id @default(autoincrement())
  link_name         String
  campaign_name     String
  value             Float
  registration_date DateTime
  ip                String?
  user_agent        String?
  created_at        DateTime @default(now())

  @@index([campaign_name])
  @@index([link_name])
  @@index([registration_date])
  @@index([created_at])
  @@map("tracking_events")
}
